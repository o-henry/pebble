# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Dependencies and build outputs
/node_modules/
/.pnpm-store/
/dist/
/build/
/coverage/
/target/
/src-tauri/target/
/src-tauri/gen/
/src-tauri/binaries/codex-*

# Local environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.p8
*.cer
*.crt
*.csr
*.mobileprovision

# Logs and local runtime state
*.log
/logs/
/tmp/
/temp/
/.tmp/
/.cache/
/.vite/

# Pebble must not persist captured content.
/captures/
/screenshots/private/
/pebble-captures/
/pebble-debug-frames/
/tmp/captures/
/tmp/pebble-captures/
/tmp/pebble-debug-frames/
*.pebble-frame

# Legacy pre-rename capture paths remain ignored for safety.
/screenpebble-captures/
/screenpebble-debug-frames/
/tmp/screenpebble-captures/
/tmp/screenpebble-debug-frames/
*.screenpebble-frame

# Packaging artifacts
*.dmg
*.app.tar.gz
*.msi
*.AppImage
