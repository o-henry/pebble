{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pebble",
  "version": "0.2.1",
  "identifier": "com.ohenry.screenpebble",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "category": "Utility",
    "externalBin": ["binaries/codex"],
    "shortDescription": "Keep a selected part of your Mac visible and watched.",
    "longDescription": "Pebble is a local-first macOS utility for pinning and watching explicitly selected screen regions.",
    "targets": ["app", "dmg"],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "14.0"
    }
  }
}
