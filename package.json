{
  "name": "pebble",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "prepare:sidecar": "node scripts/prepare-codex-sidecar.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && node --test scripts/macos-release-policy.test.mjs scripts/macos-install-policy.test.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run prepare:sidecar && tauri dev",
    "tauri:build": "npm run prepare:sidecar && tauri build",
    "release:check": "node scripts/check-macos-release.mjs",
    "release:check:signed": "node scripts/check-macos-release.mjs --require-signing",
    "release:macos": "npm run release:check:signed && npm run prepare:sidecar && tauri build --bundles app,dmg",
    "install:macos": "node scripts/install-macos-app.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@openai/codex": "0.144.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
